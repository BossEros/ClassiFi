{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "ignoreDeprecations": "5.0",
    "noEmit": true,
    "paths": {
      "@/*": ["../backend-ts/src/*"],
      "vitest": ["../backend-ts/node_modules/vitest"],
      "vitest/*": ["../backend-ts/node_modules/vitest/*"],
      "tsyringe": ["../backend-ts/node_modules/tsyringe"],
      "tsyringe/*": ["../backend-ts/node_modules/tsyringe/*"]
    }
  },
  "include": [
    "unit-tests/**/*.test.ts",
    "integration-tests/**/*.test.ts"
  ],
  "exclude": ["node_modules"]
}
